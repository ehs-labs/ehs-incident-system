source "https://rubygems.org"

ruby "3.4.1"

# ----- Core ------------------------------------------------------------------
gem "rails", "~> 7.2", ">= 7.2.3.1"
gem "pg",    "~> 1.5"
gem "puma",  "~> 6.4"
gem "bootsnap", require: false
gem "tzinfo-data", platforms: %i[mingw mswin x64_mingw jruby]

# ----- Auth ------------------------------------------------------------------
gem "devise"
gem "devise-jwt"
gem "devise_invitable"

# ----- Authorization & state machines ----------------------------------------
gem "pundit"
gem "aasm"
gem "paper_trail"

# ----- Background jobs -------------------------------------------------------
gem "sidekiq"
gem "sidekiq-cron"

# ----- Kafka + Avro ----------------------------------------------------------
gem "rdkafka"
gem "avro_turf"

# ----- Search, pagination, serialization -------------------------------------
gem "pg_search"
gem "kaminari"
gem "jsonapi-serializer"

# ----- File storage ----------------------------------------------------------
gem "aws-sdk-s3", require: false   # ActiveStorage S3 service (MinIO/AWS)
gem "image_processing"             # ActiveStorage variant processing

# ----- Web layer -------------------------------------------------------------
gem "rack-cors"
gem "dotenv-rails"

# ----- Operational signals ---------------------------------------------------
gem "strong_migrations"
gem "lograge"
gem "prometheus_exporter"
gem "opentelemetry-sdk"
gem "opentelemetry-instrumentation-rails"

# ----- Shared field-level cipher (local-path gem) ----------------------------
gem "ehs-envelope", path: "../shared/envelope"

# ----- IDs -------------------------------------------------------------------
gem "ulid-ruby", require: "ulid"

# ----- Demo seeds ------------------------------------------------------------
# Faker is used by db/demo_seeds.rb to generate realistic witnesses/comments.
# It lives in the default group (NOT :development, :test) because the
# production-style Docker image installs with BUNDLE_WITHOUT=development:test
# but still runs `bin/rails db:seed:demo` during bootstrap. Cost is small and
# nothing else loads Faker, so it stays out of the way at runtime.
gem "faker"

# ----- OpenAPI / Swagger UI --------------------------------------------------
# rswag-api serves the committed openapi.yaml; rswag-ui serves the Swagger UI
# assets. Both ship in the runtime bundle so /api-docs is reachable in the
# Docker image (built with BUNDLE_WITHOUT=development:test). Route mount is
# gated on Rails.env.development? — never exposed in production.
gem "rswag-api"
gem "rswag-ui"

group :development, :test do
  gem "rspec-rails"
  gem "factory_bot_rails"
  gem "shoulda-matchers"
  gem "rswag-specs"
  gem "rubocop-rails-omakase", require: false
  gem "brakeman", require: false
  gem "bundler-audit", require: false
end

group :development do
  gem "listen"
end

group :test do
  gem "rails-controller-testing"
  gem "simplecov", require: false
  gem "webmock"
  gem "vcr"
end
