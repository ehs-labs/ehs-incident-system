# =============================================================================
# EHS Incident System — local environment template
# Copy this file to .env and fill in real values. .env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (shared by core-api and notifier; one server, two logical DBs)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ehs
POSTGRES_PASSWORD=devpassword
POSTGRES_APP_DB=ehs_app
POSTGRES_NOTIFIER_DB=ehs_notifier

# -----------------------------------------------------------------------------
# Redis (Sidekiq backing store)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Kafka + Karapace (schema registry)
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
KARAPACE_URL=http://karapace:8081

# -----------------------------------------------------------------------------
# MinIO (S3-compatible blob store for ActiveStorage)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=ehs-attachments
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# SMTP (MailCatcher in dev — web UI at http://localhost:1080)
# -----------------------------------------------------------------------------
SMTP_HOST=mailcatcher
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@ehs.local

# -----------------------------------------------------------------------------
# Secrets — values below are DEV-ONLY DEFAULTS so the stack boots out of the
# box. NEVER use these outside local development.
#
# Generate real values for staging/production:
#   ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'           # JWT secrets
#   openssl rand -base64 32                                       # FIELD_CIPHER_KEY (32 raw bytes -> 44 b64 chars)
#
# In K8s, these are mounted from Secrets as files via FIELD_CIPHER_KEY_FILE etc.
# -----------------------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-replace-in-production-dev-jwt-secret-replace-in-prod
JWT_DENYLIST_SECRET=dev-jwt-denylist-secret-dev-jwt-denylist-secret-dev-jwt-deny-pad
# Base64 of 32 zero bytes — purely a dev placeholder; ANY base64-encoded 32-byte string works.
FIELD_CIPHER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
SIGNUP_ENABLED=true
STRICT_MIGRATION_CHECK=false

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
APP_HOST=http://localhost:5173
API_HOST=http://localhost:3000
NOTIFIER_HOST=http://localhost:4000
NOTIFIER_WS_URL=ws://localhost:4000/ws
