root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{rb,gemspec}]
indent_size = 2

[*.{js,ts,tsx,vue,json,yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4
