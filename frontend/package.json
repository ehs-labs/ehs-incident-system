{
  "name": "ehs-incident-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 5173",
    "typecheck": "vue-tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.vue,.js --max-warnings 0",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.vue,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:api": "openapi-typescript ../core-api/openapi.yaml --output src/api/generated/schema.ts"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "chart.js": "^4.4.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "naive-ui": "^2.39.0",
    "pinia": "^2.2.4",
    "vee-validate": "^4.13.2",
    "vue": "^3.5.10",
    "vue-chartjs": "^5.3.1",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.11.1",
    "eslint-plugin-vue": "^9.28.0",
    "happy-dom": "^15.7.4",
    "openapi-typescript": "^7.4.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1",
    "vue-tsc": "^2.1.6"
  }
}
