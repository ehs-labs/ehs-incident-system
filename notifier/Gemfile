# frozen_string_literal: true

source 'https://rubygems.org'

ruby '3.4.1'

# ----- Web framework + async runtime -----------------------------------------
gem 'async-websocket'
gem 'falcon'        # fiber-based async server for the WebSocket endpoint
gem 'puma'          # fallback HTTP for the /healthz endpoint
gem 'rack', '~> 3.0'
gem 'sinatra', '~> 4.0'
gem 'sinatra-contrib'

# ----- Kafka + Avro ----------------------------------------------------------
gem 'avro_turf'
gem 'karafka'

# ----- Persistence -----------------------------------------------------------
gem 'pg'
gem 'sequel'
gem 'sequel-postgres-pr', require: false # dev-only fallback if libpq missing

# ----- Email / Telegram ------------------------------------------------------
gem 'mail'
gem 'telegram-bot-ruby'

# ----- Auth (JWT verification only — issuance lives in core-api) -------------
gem 'jwt'

# ----- Shared field-level cipher ---------------------------------------------
gem 'ehs-envelope', path: '../shared/envelope'

# ----- Operational signals ---------------------------------------------------
gem 'dotenv'
gem 'lograge-sql', require: false
gem 'opentelemetry-sdk'
gem 'prometheus_exporter'

# ----- IDs -------------------------------------------------------------------
gem 'ulid-ruby', require: 'ulid'

# ----- Misc ------------------------------------------------------------------
gem 'rake'

group :development, :test do
  gem 'bundler-audit', require: false
  gem 'factory_bot'
  gem 'faker'
  gem 'karafka-testing'
  gem 'rspec'
  gem 'rubocop'
end

group :test do
  gem 'rack-test'
  gem 'simplecov', require: false
  gem 'vcr'
  gem 'webmock'
end
